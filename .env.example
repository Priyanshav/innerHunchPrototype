# ─────────────────────────────────────────────────
#  Inner Hunch — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3000

# PostgreSQL Database
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/inner_hunch

# JWT Secret — change this to any long random string
JWT_SECRET=inner-hunch-super-secret-key-change-this-in-production-2025

# Node environment
NODE_ENV=development
